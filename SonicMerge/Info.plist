<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Bundle identity — required when GENERATE_INFOPLIST_FILE = NO -->
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<!-- URL scheme registration for sonicmerge:// deep link (D-07) -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.dtech.SonicMerge</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>sonicmerge</string>
			</array>
		</dict>
	</array>
	<!-- UIApplicationSceneManifest — previously INFOPLIST_KEY_UIApplicationSceneManifest_Generation -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<!-- Previously INFOPLIST_KEY_UIApplicationSupportsIndirectInputEvents -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Launch screen — previously INFOPLIST_KEY_UILaunchScreen_Generation -->
	<key>UILaunchScreen</key>
	<dict/>
	<!-- Status bar style — previously INFOPLIST_KEY_UIStatusBarStyle -->
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDefault</string>
	<!-- Supported orientations iPad — previously INFOPLIST_KEY_UISupportedInterfaceOrientations_iPad -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Supported orientations iPhone — previously INFOPLIST_KEY_UISupportedInterfaceOrientations_iPhone -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Smart Cut: Speech.framework on-device transcription consent (sc-t13) -->
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>SonicMerge uses on-device speech recognition to detect filler words and long silences in your audio. Recognition runs entirely on your device — your audio is never uploaded.</string>
	<!-- Smart Cut: BGProcessingTask identifier — must match BackgroundTranscriptionTask.identifier (sc-t13) -->
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>com.dtech.SonicMerge.smartcut.transcribe</string>
	</array>
	<!-- Smart Cut: enable processing background mode for BGProcessingTask (sc-t13) -->
	<key>UIBackgroundModes</key>
	<array>
		<string>processing</string>
	</array>
</dict>
</plist>
